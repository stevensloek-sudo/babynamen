# Flask
FLASK_SECRET_KEY=verander-dit-naar-een-lange-willekeurige-string

# Anthropic (Claude Haiku) - VERPLICHT voor naam-generatie
ANTHROPIC_API_KEY=sk-ant-...

# Resend (e-mailverificatie) - optioneel, zonder key wordt link in console geprint
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@jouwdomein.nl

# Google OAuth - optioneel, knop is uit zonder deze keys
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mollie (betalingen) - optioneel, /upgrade meldt "nog niet actief" zonder key
MOLLIE_API_KEY=

# Basis-URL van de site (voor OAuth redirects en Mollie webhooks)
BASE_URL=http://localhost:5000

# Admin (gratis onbeperkt account)
ADMIN_EMAIL=stevensloek@gmail.com
